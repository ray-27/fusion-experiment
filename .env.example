# Copy this file to .env and fill in your token.
# If HF_TOKEN is not set here, the code falls back to the system
# environment variables HF_TOKEN / HUGGING_FACE_HUB_TOKEN.
HF_TOKEN=

# Discord webhook URL, used to notify when a training run finishes.
# If left blank, the code falls back to DISCORD_WEBHOOK_URL in the system env.
DISCORD_WEBHOOK_URL=
